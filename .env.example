# ---------------------------------------------------------------------------
# BD Investment Newsfeed – Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your real credentials.
# DO NOT commit .env — it is gitignored.

# Server
PORT=5002
FRONTEND_URL=https://your-app.vercel.app,https://your-custom-domain.com

# Supabase (https://supabase.com — Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
SUPABASE_PROJECT_PASSWORD=your-supabase-project-password-here

# Gemini API keys (https://aistudio.google.com/app/apikey — rotate across 3 keys to avoid rate limits)
GEMINI_API_KEY_1=your-gemini-api-key-1-here
GEMINI_API_KEY_2=your-gemini-api-key-2-here
GEMINI_API_KEY_3=your-gemini-api-key-3-here

# Groq API keys (https://console.groq.com/keys — rotate across 2 keys)
GROQ_API_KEY_1=your-groq-api-key-1-here
GROQ_API_KEY_2=your-groq-api-key-2-here

# SMTP Mail Server Credentials (For Conditional Email Alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-actual-email@gmail.com
SMTP_PASS=your-gmail-app-password-here
ALERT_FROM_EMAIL=your-actual-email@gmail.com